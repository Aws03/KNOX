{
  "Storage": {
    "BaseUrl": "http://localhost:5001"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_USER_SECRET",
    "Issuer": "https://localhost:7012",
    "Audience": "https://localhost:7012/swagger/",
    "ExpirationMinutes": 30
  },
  "OpenAI": {
    "ApiKey": "REPLACE_WITH_USER_SECRET",
    "Model": "gpt-4.1-mini",
    "MaxTokens": 4000,
    "Temperature": 0.7,
    "Enabled": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_USER_SECRET"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Brevo": {
    "ApiKey": "REPLACE_WITH_USER_SECRET"
  },
  "AhaSend": {
    "AccountId": "REPLACE_WITH_USER_SECRET",
    "ApiKey": "REPLACE_WITH_USER_SECRET",
    "FromEmail": "no-repley@ecampusjo.com",
    "FromName": "Uni-Hub"
  },
  "AuthSettings": {
    "RequireEmailVerificationOnRegisteration": false,
    "OTPExpiryMinutes": 10,
    "MaxOTPResendAttempts": 3
  },
  "AllowedHosts": "*"
}
